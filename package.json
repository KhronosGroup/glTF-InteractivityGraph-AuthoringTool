{
  "name": "khr_interactivity_authoring",
  "version": "0.1.0",
  "homepage": "https://github.khronos.org/glTF-InteractivityGraph-AuthoringTool",
  "private": true,
  "type": "module",
  "dependencies": {
    "@babylonjs/core": "^7.0.0",
    "@babylonjs/loaders": "^7.0.0",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "12.1.5",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/user-event": "^13.5.0",
    "@types/node": "^16.18.40",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "bootstrap": "^5.3.1",
    "gl-matrix": "^3.4.3",
    "jest-environment-jsdom": "^29.6.4",
    "react": "^18.2.0",
    "react-bootstrap": "^2.8.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "reactflow": "^11.8.2",
    "typescript": "^4.9.5",
    "uuid": "^9.0.0",
    "web-vitals": "^2.1.4"
  },
  "overrides": {
    "@testing-library/react": {
      "react": "^18.2.0",
      "react-dom": "^18.2.0"
    },
    "@testing-library/react-hooks": {
      "react": "^18.2.0",
      "react-dom": "^18.2.0",
      "@types/react": "^18.2.0"
    },
    "cypress-plugin-snapshots": {
      "cypress": "^14.2.1"
    }
  },
  "scripts": {
    "schema:generate": "node scripts/generate-object-model-schema.mjs",
    "prestart": "npm run schema:generate",
    "start": "react-scripts start",
    "prebuild": "npm run schema:generate",
    "build": "react-scripts build",
    "pretest": "npm run schema:generate",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "pretest:assets": "npm run schema:generate",
    "test:assets": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.assets.config.json --runInBand",
    "pretest:assets:core": "npm run schema:generate",
    "test:assets:core": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.assets.config.json --runInBand tst/assets/validation.asset.ts tst/assets/core.asset.ts tst/assets/overview.asset.ts tst/assets/interglb.asset.ts",
    "pretest:assets:e2e": "npm run schema:generate",
    "test:assets:e2e": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.assets.config.json --runInBand tst/assets/validation.asset.ts tst/assets/engines.asset.ts tst/assets/interglb.babylon.asset.ts",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "posttest": "generate-coverage-data",
    "lint": "eslint '**/*.{ts,tsx}'",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.22.17",
    "@babel/preset-env": "^7.22.15",
    "@babel/preset-modules": "^0.1.6",
    "@babel/preset-typescript": "^7.23.0",
    "@types/jest": "^29.5.4",
    "@types/uuid": "^9.0.2",
    "babel-jest": "^29.7.0",
    "cypress": "^14.2.1",
    "cypress-plugin-snapshots": "^1.4.4",
    "eslint": "^8.49.0",
    "jest": "^29.6.4",
    "jest-transform-css": "^6.0.1",
    "ts-jest": "^29.1.1"
  }
}
